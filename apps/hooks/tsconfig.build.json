{
  "extends": "@dotoli/typescript-config",
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": "src",
    "outDir": "dist",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "dist",
    "composite": true,
    "noEmit": false,
    "esModuleInterop": true
  },
  "include": ["src"]
}
